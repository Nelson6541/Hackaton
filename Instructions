Étape 4 — Lancer la Stack ELK
Crée un fichier docker-compose.yml :
version: '3.8'

services:
  elasticsearch:
    image: elasticsearch:8.11.0
    environment:
      - discovery.type=single-node
      - xpack.security.enabled=false
      - "ES_JAVA_OPTS=-Xms512m -Xmx512m"
    ports:
      - "9200:9200"
    volumes:
      - es_data:/usr/share/elasticsearch/data

  logstash:
    image: logstash:8.11.0
    volumes:
      - ./logstash.conf:/usr/share/logstash/pipeline/logstash.conf
    depends_on:
      - elasticsearch

  kibana:
    image: kibana:8.11.0
    ports:
      - "5601:5601"
    environment:
      - ELASTICSEARCH_HOSTS=http://elasticsearch:9200
    depends_on:
      - elasticsearch

volumes:
  es_data:
Crée le fichier logstash.conf :
input {
  file {
    path => "/usr/share/logstash/data/harmbench_results.json"
    codec => json
    start_position => "beginning"
  }
}

filter {
  mutate {
    add_field => { "[@metadata][index]" => "harmbench" }
  }
}

output {
  elasticsearch {
    hosts => ["http://elasticsearch:9200"]
    index => "harmbench-%{+YYYY.MM.dd}"
  }
}
# Lancer la stack
docker-compose up -d

# Vérifier que tout tourne
docker-compose ps
